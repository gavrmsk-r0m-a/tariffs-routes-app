TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APP_BASE_URL=http://127.0.0.1:8000

# SQLite storage
# Recommended: keep SQLite DB outside the repository/app directory.
#
# Windows local/prod-like example:
# SQLITE_DB_PATH=C:\TeleRoute\data\mvp.sqlite3
#
# Windows production example:
# SQLITE_DB_PATH=D:\TeleRoute\data\mvp.sqlite3
#
# Linux production example:
# SQLITE_DB_PATH=/var/lib/teleroute/mvp.sqlite3
#
# Alternative:
# APP_DATA_DIR=C:\TeleRoute\data
#
# Legacy:
# MVP_DB_PATH=...

# Future PostgreSQL configuration (not enabled yet):
# DATABASE_URL=postgresql://user:password@host:5432/teleroute

# HLR Lookup API
HLR_MODE=demo
HLR_API_URL=https://api.hlrlookup.com/apiv2/hlr
HLR_API_KEY=
HLR_API_SECRET=
HLR_TIMEOUT_MS=30000
HLR_CONCURRENCY=1
HLR_DAILY_CHECK_LIMIT=500
